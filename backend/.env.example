# Defaults to SQLite for zero-install local dev. Override to point at Postgres
# for production deployments.
DATABASE_URL=sqlite+aiosqlite:///./mortgage.db
DATABASE_URL_SYNC=sqlite:///./mortgage.db

ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

TRUELAYER_CLIENT_ID=your-client-id
TRUELAYER_CLIENT_SECRET=your-client-secret
TRUELAYER_REDIRECT_URI=http://localhost:3000/banking/callback
TRUELAYER_SANDBOX=true

JWT_SECRET=change-this-to-a-random-secret
FRONTEND_URL=http://localhost:3000
